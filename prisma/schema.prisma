generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  VENDOR
  ADMIN
  DELIVERY
}

enum RequestStatus {
  PENDING_ADMIN_REVISION
  OPEN_FOR_BIDDING
  BIDS_RECEIVED
  OFFERS_FORWARDED
  ORDER_PAID_PENDING_DELIVERY
  CLOSED_SUCCESS
  CLOSED_CANCELLED
  REJECTED
}

enum BidStatus {
  PENDING
  SELECTED
  ACCEPTED_BY_CLIENT
  REJECTED
  WITHDRAWN
}

enum DeliveryStatus {
  ORDER_PLACED
  VENDOR_PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  IN_TRANSIT
  DELIVERED
  FAILED_DELIVERY
  RETURNED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  ESCROW_DEPOSIT
  VENDOR_PAYOUT
  ADMIN_COMMISSION
  REFUND
  WITHDRAWAL
}

enum NotificationType {
  NEW_REQUEST
  NEW_BID
  OFFER_RECEIVED
  BID_ACCEPTED
  DELIVERY_UPDATE
  DELIVERY_FAILED
  PAYMENT_RECEIVED
  REFUND_ISSUED
  REQUEST_DISPATCHED
  WALLET_TOPUP
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
}

model User {
  id               Int            @id @default(autoincrement())
  fullName         String
  email            String         @unique
  password         String
  phone            String?
  role             UserRole
  isActive         Boolean        @default(true)
  walletBalance    Decimal        @default(0) @db.Decimal(12, 2)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  clientRequests   Request[]          @relation("ClientRequests")
  vendorBids       Bid[]
  vendorCategories VendorCategory[]
  transactions     Transaction[]
  notifications    Notification[]
  vendorWithdrawals WithdrawalRequest[] @relation("VendorWithdrawals")
  adminReviewedWithdrawals WithdrawalRequest[] @relation("AdminWithdrawalReviews")
  assignedDeliveries Request[] @relation("DeliveryAgent")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model Category {
  id        Int            @id @default(autoincrement())
  name      String         @unique
  slug      String         @unique
  createdAt DateTime       @default(now())

  requests  Request[]
  vendors   VendorCategory[]

  @@index([slug])
}

model VendorCategory {
  id         Int      @id @default(autoincrement())
  vendorId   Int
  categoryId Int
  vendor     User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([vendorId, categoryId])
  @@index([vendorId])
  @@index([categoryId])
}

model Request {
  id               Int                @id @default(autoincrement())
  clientId         Int
  title            String
  description      String
  categoryId       Int
  address          String
  latitude         Decimal            @db.Decimal(10, 7)
  longitude        Decimal            @db.Decimal(10, 7)
  deliveryPhone    String
  notes            String?
  status           RequestStatus      @default(PENDING_ADMIN_REVISION)
  selectedBidId    Int?               @unique
  qrCode                   String?
  assignedDeliveryAgentId  Int?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  client           User               @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)
  deliveryAgent    User?              @relation("DeliveryAgent", fields: [assignedDeliveryAgentId], references: [id], onDelete: SetNull)
  category         Category           @relation(fields: [categoryId], references: [id])
  images           RequestImage[]
  bids             Bid[]
  deliveryTracking DeliveryTracking[]
  transactions     Transaction[]

  @@index([clientId])
  @@index([categoryId])
  @@index([status])
}

model RequestImage {
  id        Int      @id @default(autoincrement())
  requestId Int
  filePath  String
  fileName  String
  mimeType  String
  fileSize  Int
  createdAt DateTime @default(now())

  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model Bid {
  id          Int       @id @default(autoincrement())
  requestId   Int
  vendorId    Int
  description String
  netPrice    Decimal   @db.Decimal(12, 2)
  clientPrice Decimal   @db.Decimal(12, 2)
  status      BidStatus @default(PENDING)
  adminNote   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  request     Request    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  vendor      User       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  images      BidImage[]

  @@unique([requestId, vendorId])
  @@index([requestId])
  @@index([vendorId])
  @@index([status])
}

model BidImage {
  id        Int      @id @default(autoincrement())
  bidId     Int
  filePath  String
  fileName  String
  mimeType  String
  fileSize  Int
  createdAt DateTime @default(now())

  bid       Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
}

model DeliveryTracking {
  id           Int              @id @default(autoincrement())
  requestId    Int
  status       DeliveryStatus
  note         String?
  locationText String?
  createdAt    DateTime         @default(now())

  request      Request          @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([status])
}

model Transaction {
  id          Int             @id @default(autoincrement())
  userId      Int
  requestId   Int?
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String?
  createdAt   DateTime        @default(now())

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  request     Request?        @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model WithdrawalRequest {
  id           Int              @id @default(autoincrement())
  vendorId     Int
  amount       Decimal          @db.Decimal(12, 2)
  status       WithdrawalStatus @default(PENDING)
  reviewNote   String?
  reviewedById Int?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  vendor       User             @relation("VendorWithdrawals", fields: [vendorId], references: [id], onDelete: Cascade)
  reviewedBy   User?            @relation("AdminWithdrawalReviews", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([status])
  @@index([reviewedById])
}

model PlatformSetting {
  id                    Int      @id @default(autoincrement())
  commissionPercent     Decimal  @default(15) @db.Decimal(5, 2)
  minVendorMatchCount   Int      @default(3)
  initialRadiusKm       Int      @default(5)
  maxRadiusKm           Int      @default(50)
  radiusExpansionStepKm Int      @default(5)
  updatedAt             DateTime @updatedAt
}
